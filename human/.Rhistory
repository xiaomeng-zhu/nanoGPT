clean_results_exp2_flipped <- clean_results_exp2 %>%
group_by(complement_type, sentence_type, knowledge_state, block) %>%
mutate(
choose_hidden = if(n_distinct(choose_hidden) == 1) {
idx <- sample(1:n(), 1) # sample one index from the perfect separation conditions
replace(choose_hidden, idx, 1 - choose_hidden[idx]) # replace the choose visible sign
} else choose_hidden
) %>%
ungroup()
clean_results_exp2_flipped_summarized <- clean_results_exp2_flipped %>%
group_by(complement_type, sentence_type, knowledge_state, block) %>%
summarize(rate_choose_hidden=mean(choose_hidden),
se_hidden = sd(choose_hidden) / sqrt(n()),
num_observations = n())
