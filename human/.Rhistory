exp1.bad.people <- checkExclude(exp1.results)
exp1.bad.people
exp2.bad.people <- checkExclude(exp2.results)
exp2.bad.people
exp1.bad.ids <- (exp1.prolific_ids %>%
filter(MD5.hash.of.participant.s.IP.address %in% exp1.bad.people))$Value
exp1.good.ids <- (exp1.prolific_ids %>%
filter(!(MD5.hash.of.participant.s.IP.address %in% exp1.bad.people)))$Value
exp2.bad.ids <- (exp2.prolific_ids %>%
filter(MD5.hash.of.participant.s.IP.address %in% exp2.bad.people))$Value
exp2.good.ids <- (exp2.prolific_ids %>%
filter(!(MD5.hash.of.participant.s.IP.address %in% exp2.bad.people)))$Value
length(exp1.bad.ids)
length(exp2.bad.ids)
# Check for duplicates
intersect(exp1.bad.ids, exp2.bad.ids)
intersect(exp1.good.ids, exp2.good.ids) # 5 participants good in both
intersect(exp1.bad.ids, exp2.good.ids) # one participant excluded in exp1 but good in exp2
intersects.ip <- (exp2.prolific_ids %>%
filter(Value %in% intersects.prolific))$MD5.hash.of.participant.s.IP.address
intersects.ip
exp1.clean <- exp1.results %>%
filter(trial_type=="target"&PennElementName=="character") %>%
mutate(exclude = ifelse(MD5.hash.of.participant.s.IP.address %in% exp1.bad.people, 1, 0)) %>% # 1 if to exclude, 0 to keep
filter(exclude == 0) # want all people whose exclude == 0
exp1.clean %>%
group_by(Group) %>%
summarize(num_ps = length(unique(MD5.hash.of.participant.s.IP.address)))
exp2.clean <- exp2.results %>%
filter(trial_type=="target"&PennElementName=="character") %>%
mutate(exclude = ifelse(MD5.hash.of.participant.s.IP.address %in% exp2.bad.people, 1, 0)) %>% # 1 if to exclude, 0 to keep
filter(exclude == 0) %>% # want all people who are NOT excludes
filter(!(MD5.hash.of.participant.s.IP.address %in% intersects.ip)) %>% # get rid of participants who also filled out exp1
filter(!(MD5.hash.of.participant.s.IP.address=="f178b48d7348c5d740144d7b2e4a0aa1"&Group==2)) # this participant filled out exp2 twice
intersect(exp2.clean$MD5.hash.of.participant.s.IP.address, exp1.clean$MD5.hash.of.participant.s.IP.address)
exp2.clean %>%
filter(!(MD5.hash.of.participant.s.IP.address %in% intersects.ip)) %>%
group_by(Group) %>%
summarize(num_ps = length(unique(MD5.hash.of.participant.s.IP.address)))
exp1.clean <- exp1.clean %>%
mutate(experiment="Exp1-between")
exp2.clean <- exp2.clean %>%
mutate(experiment="Exp2-within")
clean <- rbind(exp1.clean, exp2.clean)
clean_results_coded <- clean %>%
mutate(knowledge_state = factor(knowledge_state, levels=c("knowledgeable", "partial", "ignorant"))) %>%
mutate(choose_visible=ifelse(Value=="visible", 1, 0), # if choose visible, then choose_visible is 1
choose_hidden=ifelse(Value=="hidden", 1, 0), # if choose hidden, then choose_hidden is 1
)
exp1_summarized <- clean_results_coded %>%
filter(experiment=="Exp1-between") %>%
group_by(complement_type, sentence_type, knowledge_state) %>%
summarize(rate_choose_hidden=mean(choose_hidden),
se_hidden = sd(choose_hidden) / sqrt(n()),)
exp2_summarized <- clean_results_coded %>%
filter(experiment=="Exp2-within") %>%
mutate(block=case_when(Group%in%c(0,1,2)&complement_type=="CP"~"block1",
Group%in%c(0,1,2)&complement_type=="vP"~"block2",
Group%in%c(3,4,5)&complement_type=="CP"~"block2",
Group%in%c(3,4,5)&complement_type=="vP"~"block1")) %>%
group_by(complement_type, sentence_type, knowledge_state, block) %>%
summarize(rate_choose_hidden=mean(choose_hidden),
se_hidden = sd(choose_hidden) / sqrt(n()),)
clean_results_plot <- clean_results_coded %>%
group_by(complement_type, sentence_type, knowledge_state, experiment) %>%
summarize(rate_choose_hidden=mean(choose_hidden),
se_hidden = sd(choose_hidden) / sqrt(n()),) %>%
ggplot(aes(x=knowledge_state, y=rate_choose_hidden, fill=sentence_type)) +
geom_bar(stat = "identity", position="dodge") +
geom_errorbar(
aes(ymin = rate_choose_hidden - se_hidden,
ymax = rate_choose_hidden + se_hidden),
position = position_dodge(width = 0.9),
width = 0.2
) +
labs(y="Rate of choosing hidden character", x = "Knowledge State", fill="Polarity") +
ylim(0,1) +
geom_hline(
yintercept = 0.5,
linetype = "dotted",
color = "grey50",
linewidth = 1
) +
scale_fill_brewer(palette = "Set2") +
theme_minimal()+
theme(legend.position="bottom") +
facet_wrap(~experiment+complement_type)
clean_results_plot
# ggsave("exp12.pdf", clean_results_plot, height=4, width=5)
model.exp1.mixed <- glmer(choose_hidden ~  complement_type * knowledge_state * sentence_type + (1|MD5.hash.of.participant.s.IP.address),
data = subset(clean_results_coded, experiment=="Exp1-between"),
family=binomial()) # add this for logistic regression!!!!
summary(model.exp1.mixed)
bmodel.exp1.mixed <- brm(choose_hidden ~  complement_type * knowledge_state * sentence_type + (1|MD5.hash.of.participant.s.IP.address),
data = subset(clean_results_coded, experiment=="Exp1-between"),
family=bernoulli()) # add this for logistic regression!!!!
summary(bmodel.exp1.mixed)
plot(allEffects(model.exp1.mixed))
parameters(model.exp1.mixed)
Anova(model.exp1.mixed)
